# ─── DATABASE ───────────────────────────────────────────────
# Provided automatically by Replit (runtime-managed, do not set manually)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── APP ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
SESSION_SECRET=ganti-dengan-string-acak-panjang-min-32-karakter
PROD_URL=https://gustafta.my.id

# ─── ADMIN ──────────────────────────────────────────────────
SUPERADMIN_EMAILS=penshopx@gmail.com
SUPERADMIN_PHONE=+628xxxxxxxxxx
ADMIN_USER_IDS=
LEGAL_ADMIN_KEY=ganti-dengan-key-rahasia-anda

# ─── AI — OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: override the OpenAI model used by the model router (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ─── AI — Gemini ────────────────────────────────────────────
GEMINI_API_KEY=AIza...
AI_INTEGRATIONS_GEMINI_API_KEY=AIza...
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Optional: override the Gemini model used by the model router (default: gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# ─── AI — DeepSeek (optional) ───────────────────────────────
# Leave blank to disable DeepSeek as a model option
DEEPSEEK_API_KEY=sk-...
# Optional: override model (default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# ─── AI — Qwen (optional) ───────────────────────────────────
# Leave blank to disable Qwen as a model option
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Optional: override model (default: qwen-plus)
QWEN_MODEL=qwen-plus

# ─── AI — OpenRouter (optional) ─────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o

# ─── AI — NVIDIA (optional) ─────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ─── PAYMENT — Mayar (primary) ──────────────────────────────
# https://mayar.id — main payment gateway for subscriptions & products
MAYAR_API_KEY=hl_...
MAYAR_WEBHOOK_SECRET=whsec_...

# ─── PAYMENT — Scalev (delivery pipeline) ───────────────────
# Scalev relays purchase events and triggers post-payment product delivery
SCALEV_API_KEY=...
SCALEV_SIGNING_SECRET=...
SCALEV_WEBHOOK_SECRET=...
SCALEV_CHATBOT_SLUG=gustafta
# Set to "true" to reject webhooks with invalid signatures (recommended in prod)
SCALEV_SIGNATURE_STRICT=true

# ─── PAYMENT — Midtrans (legacy, optional) ──────────────────
# Only needed if Midtrans payment flows are still active
# MIDTRANS_SERVER_KEY=Mid-server-...
# MIDTRANS_CLIENT_KEY=Mid-client-...

# ─── EMAIL — Brevo ──────────────────────────────────────────
# https://brevo.com — transactional email & OTP for @gmail.com users
# Without this, email-based login/OTP will fail silently in production
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=noreply@gustafta.com
# Optional: secret to verify Brevo webhook events
# BREVO_WEBHOOK_SECRET=...

# ─── WHATSAPP OTP — Fonnte ──────────────────────────────────
# https://fonnte.com — WhatsApp channel for OTP (default for non-@gmail users)
# FONNTE_API_KEY and FONNTE_API_TOKEN are both read; set at least one.
FONNTE_API_KEY=...
FONNTE_API_TOKEN=...

# ─── META / Facebook (optional) ─────────────────────────────
# Conversions API for server-side purchase event tracking
META_PIXEL_ID=...
META_CAPI_ACCESS_TOKEN=...
# Optional: for Meta test events (remove in production)
# META_TEST_EVENT_CODE=TEST12345

# ─── ANALYTICS / DATA (optional) ────────────────────────────
BPS_API_KEY=...
TENDER_INGEST_KEY=...

# ─── BACKUP (optional) ──────────────────────────────────────
BACKUP_RECIPIENT_EMAIL=admin@gustafta.com
