#!/usr/bin/env bash
# pre-commit hook: block staged files that contain plaintext secrets.
# Installed automatically by: bash scripts/install-hooks.sh
#
# To add a new pattern, append to PATTERNS below and re-run install-hooks.sh.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ── Secret patterns (grep extended-regex) ─────────────────────────────────────
PATTERNS=(
  # Brevo (Sendinblue) API key
  'xkeysib-[A-Za-z0-9_-]{10,}'
  # OpenAI API key (sk-... or sk-proj-...)
  'sk-[A-Za-z0-9_-]{20,}'
  # Scalev / generic sk_ prefixed keys
  'sk_[A-Za-z0-9_-]{10,}'
  # Fonnte / WhatsApp gateway token inline assignment
  'FONNTE_API_KEY\s*=\s*[A-Za-z0-9_-]{10,}'
  # Generic Bearer token value
  'Bearer [A-Za-z0-9._~+/-]{20,}'
  # .replit [userenv.shared] block — the recurring leak surface
  '\[userenv\.shared\]'
  # KEY=<long-value> for all known secret env vars
  '(DEEPSEEK|GEMINI|QWEN|NVIDIA|OPENROUTER|META_CAPI|META_PIXEL|SCALEV|BREVO|FONNTE|TENDER_INGEST|SESSION_SECRET)[_A-Z]*(API_KEY|ACCESS_TOKEN|WEBHOOK_SECRET|KEY)?\s*=\s*[A-Za-z0-9_\-\.]{16,}'
)

# ── File paths to skip (regex anchored at start) ──────────────────────────────
SKIP_PATTERNS=(
  '^\.git/'
  '^node_modules/'
  '^dist/'
  '^\.agents/memory/'
  '^scripts/install-hooks\.sh$'
  '^scripts/hooks/'
)

# ── Main ──────────────────────────────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null) || true
[[ -z "$STAGED" ]] && exit 0

FOUND=0

for FILE in $STAGED; do
  [[ -f "$FILE" ]] || continue

  SKIP=0
  for SKIP_PAT in "${SKIP_PATTERNS[@]}"; do
    if echo "$FILE" | grep -qE "$SKIP_PAT"; then SKIP=1; break; fi
  done
  [[ $SKIP -eq 1 ]] && continue

  for PAT in "${PATTERNS[@]}"; do
    MATCH=$(git show ":$FILE" 2>/dev/null | grep -nE "$PAT" || true)
    if [[ -n "$MATCH" ]]; then
      if [[ $FOUND -eq 0 ]]; then
        echo -e "\n${RED}✖  SECRET DETECTED — commit blocked${NC}"
        echo -e "${YELLOW}Remove the secret value(s) below, then re-stage and commit.${NC}\n"
      fi
      echo -e "${RED}File    : $FILE${NC}"
      echo -e "${YELLOW}Pattern : $PAT${NC}"
      echo "$MATCH" | head -5 | sed 's/^/  /'
      echo ""
      FOUND=1
      break
    fi
  done
done

if [[ $FOUND -ne 0 ]]; then
  echo -e "${RED}Commit aborted.${NC}"
  echo ""
  echo "  • Store secrets in Replit Secrets — never in .replit, .env, or any tracked file."
  echo "  • If a key already reached git history → rotate it at the provider dashboard."
  echo ""
  exit 1
fi

exit 0
