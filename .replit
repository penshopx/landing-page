modules = ["nodejs-20", "web", "python-3.12", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"
packages = ["git"]

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development npx tsx server/index.ts"
waitForPort = 5000

[agent]
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_log_in_with_replit:2.0.0", "javascript_database:1.0.0", "notion:1.0.0", "javascript_gemini_ai_integrations:2.0.0"]
stack = "FULLSTACK_JS"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 23636
externalPort = 80

[userenv]

[userenv.shared]
ADMIN_EMAILS = "tutip98@outlook.com"
ADMIN_USER_IDS = "58349984,58848919,59024982"
BREVO_SENDER_EMAIL = "noreply@gustafta.com"
DEEPSEEK_MODEL = "deepseek-chat"
GEMINI_MODEL = "gemini-2.5-pro"
OPENAI_MODEL = "gpt-4o"
PROD_URL = "https://gustafta.my.id"
QWEN_MODEL = "qwen-plus"
SCALEV_CHATBOT_SLUG = "gustafta"
SCALEV_SIGNATURE_STRICT = "true"
SMTP_HOST = "smtp-relay.brevo.com"
SMTP_PORT = "587"
SUPERADMIN_EMAILS = "penshopx@gmail.com"
